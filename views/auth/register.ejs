<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - Car Rental System</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🚗 Car Rental System</h1>
            <p>Quản lý cho thuê ô tô chuyên nghiệp</p>
        </header>

        <nav>
            <ul>
                <li><a href="/">🏠 Trang Chủ</a></li>
                <li><a href="/auth/login">🔐 Đăng nhập</a></li>
            </ul>
        </nav>

        <main>
            <div class="content">
                <h2>Đăng ký</h2>
                <% if (success) { %>
                    <div class="alert success"><%= success %></div>
                <% } %>
                <% if (error) { %>
                    <div class="alert error"><%= error %></div>
                <% } %>
                <form action="/auth/register" method="post">
                    <label>Username: <input type="text" name="username" required></label><br>
                    <label>Password: <input type="password" name="password" required></label><br>
                    <button type="submit">Đăng ký</button>
                </form>
                <p>Sau khi đăng ký, bạn sẽ được chuyển tới trang đăng nhập.</p>
            </div>
        </main>

        <footer>
            <p>&copy; 2024 Car Rental System | All rights reserved</p>
        </footer>
    </div>
</body>
</html>